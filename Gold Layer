{"cells":[{"cell_type":"markdown","source":["**1. Import libraries**"],"metadata":{},"id":"58212208-8b72-4aa7-b93d-532647213069"},{"cell_type":"code","source":["from pyspark.sql.functions import *\n","from pyspark.sql.types import *\n","from pyspark.sql.window import Window\n","from delta.tables import DeltaTable\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"16ac5384-f95a-4eb7-b406-1b6574732ffa"},{"cell_type":"markdown","source":["**2. Configuration**"],"metadata":{},"id":"7f501fd4-7cc9-452c-967b-6e9e2c8889d7"},{"cell_type":"code","source":["SILVER_CUSTOMER_TABLE = \"dbo.customer_master_silver\"\n","SILVER_SALES_TABLE    = \"dbo.sales_transactions_silver\"\n","\n","DIM_DATE_TABLE        = \"dbo.dim_date\"\n","DIM_CUSTOMER_TABLE    = \"dbo.dim_customer\"\n","DIM_PRODUCT_TABLE     = \"dbo.dim_product\"\n","FACT_SALES_TABLE      = \"dbo.fact_sales\"\n","\n","HIGH_DATE = \"9999-12-31\"\n","RESET_ALL = False\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"754dfed7-6fc2-4999-8216-88b57bf29494"},{"cell_type":"markdown","source":["**3. Create dim_date table if it does not exist**"],"metadata":{},"id":"0d85311e-99f6-4d83-a129-654f33046546"},{"cell_type":"code","source":["DeltaTable.createIfNotExists(spark) \\\n","    .tableName(DIM_DATE_TABLE) \\\n","    .addColumn(\"DateKey\", IntegerType()) \\\n","    .addColumn(\"FullDate\", DateType()) \\\n","    .addColumn(\"DayOfMonthNumber\", IntegerType()) \\\n","    .addColumn(\"MonthOfYearNumber\", IntegerType()) \\\n","    .addColumn(\"MonthName\", StringType()) \\\n","    .addColumn(\"QuarterOfYearNumber\", IntegerType()) \\\n","    .addColumn(\"CalendarYearNumber\", IntegerType()) \\\n","    .addColumn(\"DayOfWeekNumber\", IntegerType()) \\\n","    .addColumn(\"DayOfWeekName\", StringType()) \\\n","    .execute()\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"2b77d19d-ea67-446b-b208-024125286db9"},{"cell_type":"markdown","source":["**4. Create dim_customer table if it does not exist**"],"metadata":{},"id":"f51216cf-4e41-4a29-93d9-1d6aa9a22545"},{"cell_type":"code","source":["DeltaTable.createIfNotExists(spark) \\\n","    .tableName(DIM_CUSTOMER_TABLE) \\\n","    .addColumn(\"CustomerRecordID\", LongType()) \\\n","    .addColumn(\"CustomerID\", StringType()) \\\n","    .addColumn(\"CustomerFullName\", StringType()) \\\n","    .addColumn(\"EmailAddress\", StringType()) \\\n","    .addColumn(\"CityName\", StringType()) \\\n","    .addColumn(\"MembershipTierName\", StringType()) \\\n","    .addColumn(\"EffectiveStartDate\", DateType()) \\\n","    .addColumn(\"EffectiveEndDate\", DateType()) \\\n","    .addColumn(\"CurrentFlag\", BooleanType()) \\\n","    .addColumn(\"ChangeHashValue\", StringType()) \\\n","    .execute()\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"998320d5-3526-40ba-98b5-bea3cbdb7dba"},{"cell_type":"markdown","source":["**5. Create dim_product table if it does not exist**"],"metadata":{},"id":"12ad7f2d-b3e5-4c47-916b-78ea100b1fed"},{"cell_type":"code","source":["DeltaTable.createIfNotExists(spark) \\\n","    .tableName(DIM_PRODUCT_TABLE) \\\n","    .addColumn(\"ProductRecordID\", LongType()) \\\n","    .addColumn(\"ProductID\", StringType()) \\\n","    .addColumn(\"ProductName\", StringType()) \\\n","    .execute()\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"3bd424c1-ef8f-41aa-bee1-9253f9e6ca74"},{"cell_type":"markdown","source":["**6. Create fact_sales table if it does not exist**"],"metadata":{},"id":"61c1c46d-a3c9-4c0d-bca3-59831197f45b"},{"cell_type":"code","source":["DeltaTable.createIfNotExists(spark) \\\n","    .tableName(FACT_SALES_TABLE) \\\n","    .addColumn(\"SalesTransactionRecordID\", StringType()) \\\n","    .addColumn(\"OrderID\", StringType()) \\\n","    .addColumn(\"OrderLineNumber\", IntegerType()) \\\n","    .addColumn(\"OrderDateKey\", IntegerType()) \\\n","    .addColumn(\"CustomerRecordID\", LongType()) \\\n","    .addColumn(\"ProductRecordID\", LongType()) \\\n","    .addColumn(\"OrderDate\", DateType()) \\\n","    .addColumn(\"OrderQuantity\", IntegerType()) \\\n","    .addColumn(\"UnitPriceAmount\", DoubleType()) \\\n","    .addColumn(\"TaxAmount\", DoubleType()) \\\n","    .addColumn(\"LoadTimestamp\", TimestampType()) \\\n","    .execute()\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"3ba191aa-6967-44d3-8446-e2c556471879"},{"cell_type":"markdown","source":["**7. Optional reset of all Gold tables**"],"metadata":{},"id":"9367fe80-a738-4aff-aa61-4be36d72aa08"},{"cell_type":"code","source":["if RESET_ALL:\n","    spark.sql(f\"DELETE FROM {DIM_DATE_TABLE}\")\n","    spark.sql(f\"DELETE FROM {DIM_CUSTOMER_TABLE}\")\n","    spark.sql(f\"DELETE FROM {DIM_PRODUCT_TABLE}\")\n","    spark.sql(f\"DELETE FROM {FACT_SALES_TABLE}\")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"ba49f3b6-15de-433c-bcb7-2ef3761f3c46"},{"cell_type":"markdown","source":["**8. Read Silver source tables**"],"metadata":{},"id":"71585e9a-bffa-4c16-a65b-b558f175c163"},{"cell_type":"code","source":["customer_silver_df = spark.read.table(SILVER_CUSTOMER_TABLE)\n","sales_silver_df = spark.read.table(SILVER_SALES_TABLE)\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"05646d20-35f1-4150-b276-cc2745947190"},{"cell_type":"markdown","source":["**9. Build dim_date source**"],"metadata":{},"id":"4d16865c-788a-49d4-b326-023393666803"},{"cell_type":"code","source":["date_source_df = (\n","    customer_silver_df.select(to_date(col(\"RecordDate\")).alias(\"SourceDate\"))\n","    .unionByName(sales_silver_df.select(to_date(col(\"OrderDate\")).alias(\"SourceDate\")))\n","    .filter(col(\"SourceDate\").isNotNull())\n","    .dropDuplicates([\"SourceDate\"])\n","    .withColumn(\"DateKey\", date_format(col(\"SourceDate\"), \"yyyyMMdd\").cast(\"int\"))\n","    .withColumn(\"DayOfMonthNumber\", dayofmonth(col(\"SourceDate\")))\n","    .withColumn(\"MonthOfYearNumber\", month(col(\"SourceDate\")))\n","    .withColumn(\"MonthName\", date_format(col(\"SourceDate\"), \"MMMM\"))\n","    .withColumn(\"QuarterOfYearNumber\", quarter(col(\"SourceDate\")))\n","    .withColumn(\"CalendarYearNumber\", year(col(\"SourceDate\")))\n","    .withColumn(\"DayOfWeekNumber\", dayofweek(col(\"SourceDate\")))\n","    .withColumn(\"DayOfWeekName\", date_format(col(\"SourceDate\"), \"EEEE\"))\n","    .select(\n","        \"DateKey\",\n","        col(\"SourceDate\").alias(\"FullDate\"),\n","        \"DayOfMonthNumber\",\n","        \"MonthOfYearNumber\",\n","        \"MonthName\",\n","        \"QuarterOfYearNumber\",\n","        \"CalendarYearNumber\",\n","        \"DayOfWeekNumber\",\n","        \"DayOfWeekName\"\n","    )\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"9f5f3889-782f-4a67-be35-80c2ae2b716c"},{"cell_type":"markdown","source":["**10. Merge into dim_date**"],"metadata":{},"id":"3922af40-86e5-4536-acf0-6400465ca897"},{"cell_type":"code","source":["DeltaTable.forName(spark, DIM_DATE_TABLE).alias(\"tgt\").merge(\n","    date_source_df.alias(\"src\"),\n","    \"tgt.DateKey = src.DateKey\"\n",").whenNotMatchedInsert(values={\n","    \"DateKey\": \"src.DateKey\",\n","    \"FullDate\": \"src.FullDate\",\n","    \"DayOfMonthNumber\": \"src.DayOfMonthNumber\",\n","    \"MonthOfYearNumber\": \"src.MonthOfYearNumber\",\n","    \"MonthName\": \"src.MonthName\",\n","    \"QuarterOfYearNumber\": \"src.QuarterOfYearNumber\",\n","    \"CalendarYearNumber\": \"src.CalendarYearNumber\",\n","    \"DayOfWeekNumber\": \"src.DayOfWeekNumber\",\n","    \"DayOfWeekName\": \"src.DayOfWeekName\"\n","}).execute()\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"ca0399cf-31a1-48f1-9ac1-2a83aac7c83b"},{"cell_type":"markdown","source":["**11. Build dim_product source**"],"metadata":{},"id":"82d493a0-8582-4dd9-95e1-7ede76572ad5"},{"cell_type":"code","source":["product_source_df = (\n","    sales_silver_df\n","    .select(\n","        trim(col(\"ProductID\")).alias(\"ProductID\"),\n","        trim(col(\"ProductName\")).alias(\"ProductName\")\n","    )\n","    .filter(col(\"ProductID\").isNotNull() & (col(\"ProductID\") != \"\"))\n","    .dropDuplicates([\"ProductID\", \"ProductName\"])\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"886a0b85-77e2-4050-af5f-9b7b0494d1da"},{"cell_type":"markdown","source":["**12. Identify new products**"],"metadata":{},"id":"73d28338-f837-4e0d-a1e9-52e4cb1b6a09"},{"cell_type":"code","source":["existing_product_df = spark.read.table(DIM_PRODUCT_TABLE)\n","\n","new_product_df = (\n","    product_source_df.alias(\"src\")\n","    .join(\n","        existing_product_df.alias(\"tgt\"),\n","        col(\"src.ProductID\") == col(\"tgt.ProductID\"),\n","        \"left_anti\"\n","    )\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"fec57275-5de6-45ae-ab47-10e11611fefe"},{"cell_type":"markdown","source":["**13. Insert new products into dim_product**"],"metadata":{},"id":"40be9160-0ac0-4464-b855-fe95f9bdf665"},{"cell_type":"code","source":["if new_product_df.count() > 0:\n","    max_product_id = existing_product_df.agg(\n","        coalesce(max(\"ProductRecordID\"), lit(0)).alias(\"MaxProductRecordID\")\n","    ).collect()[0][\"MaxProductRecordID\"]\n","\n","    new_product_df = (\n","        new_product_df\n","        .withColumn(\n","            \"ProductRecordID\",\n","            (row_number().over(Window.orderBy(\"ProductID\")) + lit(int(max_product_id))).cast(\"long\")\n","        )\n","        .select(\"ProductRecordID\", \"ProductID\", \"ProductName\")\n","    )\n","\n","    new_product_df.write.format(\"delta\").mode(\"append\").saveAsTable(DIM_PRODUCT_TABLE)\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"e784710a-f2a4-4de7-a091-1cec22d673cb"},{"cell_type":"markdown","source":["**14. Build customer version source**"],"metadata":{},"id":"6c508403-47c3-49f6-b046-6c2bf63bed0b"},{"cell_type":"code","source":["customer_source_df = (\n","    customer_silver_df\n","    .select(\n","        trim(col(\"CustomerID\")).alias(\"CustomerID\"),\n","        trim(col(\"FullName\")).alias(\"CustomerFullName\"),\n","        lower(trim(col(\"Email\"))).alias(\"EmailAddress\"),\n","        trim(col(\"City\")).alias(\"CityName\"),\n","        trim(col(\"MembershipTier\")).alias(\"MembershipTierName\"),\n","        to_date(col(\"RecordDate\")).alias(\"EffectiveStartDate\")\n","    )\n","    .filter(col(\"CustomerID\").isNotNull() & (col(\"CustomerID\") != \"\"))\n","    .withColumn(\n","        \"ChangeHashValue\",\n","        sha2(\n","            concat_ws(\n","                \"|\",\n","                coalesce(col(\"CustomerFullName\"), lit(\"\")),\n","                coalesce(col(\"EmailAddress\"), lit(\"\")),\n","                coalesce(col(\"CityName\"), lit(\"\")),\n","                coalesce(col(\"MembershipTierName\"), lit(\"\"))\n","            ),\n","            256\n","        )\n","    )\n","    .dropDuplicates([\"CustomerID\", \"CustomerFullName\", \"EmailAddress\", \"CityName\", \"MembershipTierName\", \"EffectiveStartDate\", \"ChangeHashValue\"])\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"06dc2931-8cc4-4fdf-a365-a8c4e27cfa1c"},{"cell_type":"markdown","source":["**15. Remove unchanged repeated customer snapshots**"],"metadata":{},"id":"c44fc215-a7bf-48e4-bcce-81cba3f82bbb"},{"cell_type":"code","source":["customer_version_window = Window.partitionBy(\"CustomerID\").orderBy(\"EffectiveStartDate\")\n","\n","customer_source_df = (\n","    customer_source_df\n","    .withColumn(\"PreviousHashValue\", lag(\"ChangeHashValue\").over(customer_version_window))\n","    .filter(\n","        col(\"PreviousHashValue\").isNull() |\n","        (col(\"ChangeHashValue\") != col(\"PreviousHashValue\"))\n","    )\n","    .drop(\"PreviousHashValue\")\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"0e59da27-1d1b-4234-a4ab-4bec1d1901d5"},{"cell_type":"markdown","source":["**16. Derive customer history end dates and current flag**"],"metadata":{},"id":"677cd452-d422-4995-8703-2c48e8fb5739"},{"cell_type":"code","source":["customer_history_window = Window.partitionBy(\"CustomerID\").orderBy(\"EffectiveStartDate\")\n","customer_record_window = Window.orderBy(\"CustomerID\", \"EffectiveStartDate\")\n","\n","customer_history_df = (\n","    customer_source_df\n","    .withColumn(\n","        \"EffectiveEndDate\",\n","        coalesce(\n","            lead(\"EffectiveStartDate\").over(customer_history_window),\n","            to_date(lit(HIGH_DATE))\n","        )\n","    )\n","    .withColumn(\n","        \"CurrentFlag\",\n","        when(col(\"EffectiveEndDate\") == to_date(lit(HIGH_DATE)), lit(True)).otherwise(lit(False))\n","    )\n","    .withColumn(\n","        \"CustomerRecordID\",\n","        row_number().over(customer_record_window).cast(\"long\")\n","    )\n","    .select(\n","        \"CustomerRecordID\",\n","        \"CustomerID\",\n","        \"CustomerFullName\",\n","        \"EmailAddress\",\n","        \"CityName\",\n","        \"MembershipTierName\",\n","        \"EffectiveStartDate\",\n","        \"EffectiveEndDate\",\n","        \"CurrentFlag\",\n","        \"ChangeHashValue\"\n","    )\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"b3d9c43d-c4de-439a-a9f6-bf971616d5d1"},{"cell_type":"markdown","source":["**17. Rebuild dim_customer from derived history**"],"metadata":{},"id":"1c9c567a-26f0-49c5-8f4e-b2d7600fd2bb"},{"cell_type":"code","source":["spark.sql(f\"DROP TABLE IF EXISTS {DIM_CUSTOMER_TABLE}\")\n","customer_history_df.write.format(\"delta\").mode(\"overwrite\").saveAsTable(DIM_CUSTOMER_TABLE)\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"de80dcb1-0e0f-4c44-b76d-69075e61a5cb"},{"cell_type":"markdown","source":["**18. Read Gold dimensions for fact build**"],"metadata":{},"id":"33701227-db1e-475f-9c8c-41b5c9dbda32"},{"cell_type":"code","source":["dim_date_df = spark.read.table(DIM_DATE_TABLE)\n","dim_customer_df = spark.read.table(DIM_CUSTOMER_TABLE)\n","dim_product_df = spark.read.table(DIM_PRODUCT_TABLE)\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"a3d53025-ca6a-434a-b05a-430f678fb412"},{"cell_type":"markdown","source":["**19. Build fact_sales source using full-history customer join**"],"metadata":{},"id":"c134e42b-d88a-49bb-a7a8-67d78d361bb1"},{"cell_type":"code","source":["fact_source_df = (\n","    sales_silver_df.alias(\"s\")\n","    .withColumn(\"OrderDate\", to_date(col(\"OrderDate\")))\n","    .join(\n","        dim_date_df.alias(\"d\"),\n","        col(\"OrderDate\") == col(\"d.FullDate\"),\n","        \"inner\"\n","    )\n","    .join(\n","        dim_customer_df.alias(\"c\"),\n","        (trim(col(\"s.CustomerID\")) == col(\"c.CustomerID\")) &\n","        (col(\"OrderDate\") >= col(\"c.EffectiveStartDate\")) &\n","        (col(\"OrderDate\") < col(\"c.EffectiveEndDate\")),\n","        \"inner\"\n","    )\n","    .join(\n","        dim_product_df.alias(\"p\"),\n","        trim(col(\"s.ProductID\")) == col(\"p.ProductID\"),\n","        \"inner\"\n","    )\n","    .select(\n","        sha2(concat_ws(\"|\", col(\"s.OrderID\"), col(\"s.OrderLine\").cast(\"string\")), 256).alias(\"SalesTransactionRecordID\"),\n","        col(\"s.OrderID\").alias(\"OrderID\"),\n","        col(\"s.OrderLine\").cast(\"int\").alias(\"OrderLineNumber\"),\n","        col(\"d.DateKey\").alias(\"OrderDateKey\"),\n","        col(\"c.CustomerRecordID\").alias(\"CustomerRecordID\"),\n","        col(\"p.ProductRecordID\").alias(\"ProductRecordID\"),\n","        col(\"OrderDate\").alias(\"OrderDate\"),\n","        col(\"s.Quantity\").cast(\"int\").alias(\"OrderQuantity\"),\n","        col(\"s.UnitPrice\").cast(\"double\").alias(\"UnitPriceAmount\"),\n","        col(\"s.Tax\").cast(\"double\").alias(\"TaxAmount\"),\n","        current_timestamp().alias(\"LoadTimestamp\")\n","    )\n","    .dropDuplicates([\"SalesTransactionRecordID\"])\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"3ba426e7-f643-4adb-bcb6-a579bbd8d6c8"},{"cell_type":"markdown","source":["**20. Merge into fact_sales**"],"metadata":{},"id":"130b71c9-8218-44f8-a265-d8d4a2e23c72"},{"cell_type":"code","source":["DeltaTable.forName(spark, FACT_SALES_TABLE).alias(\"tgt\").merge(\n","    fact_source_df.alias(\"src\"),\n","    \"tgt.SalesTransactionRecordID = src.SalesTransactionRecordID\"\n",").whenMatchedUpdate(set={\n","    \"OrderDateKey\": \"src.OrderDateKey\",\n","    \"CustomerRecordID\": \"src.CustomerRecordID\",\n","    \"ProductRecordID\": \"src.ProductRecordID\",\n","    \"OrderDate\": \"src.OrderDate\",\n","    \"OrderQuantity\": \"src.OrderQuantity\",\n","    \"UnitPriceAmount\": \"src.UnitPriceAmount\",\n","    \"TaxAmount\": \"src.TaxAmount\",\n","    \"LoadTimestamp\": \"src.LoadTimestamp\"\n","}).whenNotMatchedInsert(values={\n","    \"SalesTransactionRecordID\": \"src.SalesTransactionRecordID\",\n","    \"OrderID\": \"src.OrderID\",\n","    \"OrderLineNumber\": \"src.OrderLineNumber\",\n","    \"OrderDateKey\": \"src.OrderDateKey\",\n","    \"CustomerRecordID\": \"src.CustomerRecordID\",\n","    \"ProductRecordID\": \"src.ProductRecordID\",\n","    \"OrderDate\": \"src.OrderDate\",\n","    \"OrderQuantity\": \"src.OrderQuantity\",\n","    \"UnitPriceAmount\": \"src.UnitPriceAmount\",\n","    \"TaxAmount\": \"src.TaxAmount\",\n","    \"LoadTimestamp\": \"src.LoadTimestamp\"\n","}).execute()\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"4e7d5728-8179-453f-918b-9be12d12c7e1"},{"cell_type":"markdown","source":["**21. Show Gold table counts**"],"metadata":{},"id":"f688f44b-dd31-4e15-9d2b-8183ebf69f0e"},{"cell_type":"code","source":["print(\"dim_date count:\", spark.read.table(DIM_DATE_TABLE).count())\n","print(\"dim_customer count:\", spark.read.table(DIM_CUSTOMER_TABLE).count())\n","print(\"dim_product count:\", spark.read.table(DIM_PRODUCT_TABLE).count())\n","print(\"fact_sales count:\", spark.read.table(FACT_SALES_TABLE).count())\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"f448ba74-34a4-4724-a46d-ff45c2c61406"},{"cell_type":"markdown","source":["**22. Check duplicate current customer rows**"],"metadata":{},"id":"a234a990-e10f-4ee7-9b4d-1401754145dd"},{"cell_type":"code","source":["display(\n","    spark.read.table(DIM_CUSTOMER_TABLE)\n","    .filter(col(\"CurrentFlag\") == True)\n","    .groupBy(\"CustomerID\")\n","    .count()\n","    .filter(col(\"count\") > 1)\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"c1089b7e-cc36-47c8-ac62-fc70fb580115"},{"cell_type":"markdown","source":["**23. Display dim_customer history**"],"metadata":{},"id":"2ae9d958-0e58-4849-a408-b270bc730b62"},{"cell_type":"code","source":["display(\n","    spark.read.table(DIM_CUSTOMER_TABLE)\n","    .orderBy(\"CustomerID\", \"EffectiveStartDate\")\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"2fc21081-3fe1-4673-ad55-10be9c060d4c"},{"cell_type":"markdown","source":["**24. Display fact_sales joined to dim_customer history**"],"metadata":{},"id":"ef8fe045-8c9a-4b23-b9ea-f66d01dce6f0"},{"cell_type":"code","source":["display(\n","    spark.read.table(FACT_SALES_TABLE).alias(\"f\")\n","    .join(\n","        spark.read.table(DIM_CUSTOMER_TABLE).alias(\"c\"),\n","        col(\"f.CustomerRecordID\") == col(\"c.CustomerRecordID\")\n","    )\n","    .select(\n","        \"f.OrderID\",\n","        \"f.OrderLineNumber\",\n","        \"f.OrderDate\",\n","        \"c.CustomerID\",\n","        \"c.CustomerFullName\",\n","        \"c.EffectiveStartDate\",\n","        \"c.EffectiveEndDate\",\n","        \"c.CurrentFlag\"\n","    )\n","    .orderBy(\"f.OrderDate\", \"f.OrderID\")\n",")\n"],"outputs":[],"execution_count":null,"metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"id":"bfd59146-cfd8-493d-8bc9-6a7ffa6e7b83"}],"metadata":{"language_info":{"name":"python"},"kernelspec":{"name":"synapse_pyspark","display_name":"Synapse PySpark"},"microsoft":{"language":"python","language_group":"synapse_pyspark","ms_spell_check":{"ms_spell_check_language":"en"}},"nteract":{"version":"nteract-front-end@1.0.0"},"spark_compute":{"compute_id":"/trident/default","session_options":{"conf":{"spark.synapse.nbs.session.timeout":"1200000"}}},"kernel_info":{"name":"synapse_pyspark"},"dependencies":{"lakehouse":{"known_lakehouses":[{"id":"758e8bd0-f388-4b29-8c79-99513646b5d4"}],"default_lakehouse":"758e8bd0-f388-4b29-8c79-99513646b5d4","default_lakehouse_name":"ObinwanneLH","default_lakehouse_workspace_id":"8da34253-83f6-41e4-ae50-6fd27dcc061e"}}},"nbformat":4,"nbformat_minor":5}